MODE=realtime
SOURCE_TYPE=directory
SOURCE_PATH=./data

ASTA_MODEL_PATH=./models/model-best.h5
DETECTION_THRESHOLD=0.35

MAX_QUEUE_SIZE=128
SAMPLE_EVERY_N=1

WEATHER_MODE=classical
WEATHER_QUALITY_THRESHOLD=0.16
WEATHER_CLOUD_COV_THRESHOLD=0.80
WEATHER_SKIP_BAD_FRAMES=true
WEATHER_CLOUD_MODEL_ID=cloudmask.deeplabv3_resnet50_coco
WEATHER_IMAGE_MODEL_ID=restormer.real_denoising
WEATHER_VIDEO_MODEL_ID=rvrt.video_denoising_davis

STRICT_NORAD_MODE=true
REQUIRE_NORAD_FOR_MARKING=true
MAX_RADEC_ROUNDTRIP_PX=2.5
MAX_KNOWN_TLE_AGE_DAYS=7
REQUIRE_OBSERVER_FOR_KNOWN=true

OBSERVER_LAT=0.0
OBSERVER_LON=0.0
OBSERVER_ALT_M=0.0

TLE_ACTIVE_PATH=./data/tle_active.txt
TLE_HISTORICAL_PATH=

OUTPUT_DIR=./outputs
